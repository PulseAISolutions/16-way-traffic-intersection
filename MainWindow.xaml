<Window x:Class="TrafficIntersection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="8-Intersection Traffic Simulator" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#EAEAEA" FontFamily="Segoe UI, Inter, Arial, sans-serif">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- Main Area for Intersections -->
        <Viewbox Grid.Column="0" Stretch="Uniform">
            <!-- Canvas is 1700x900 to fit the 4x2 grid -->
            <Canvas Name="IntersectionCanvas" Width="1700" Height="900" Background="#D5CDBF" MouseDown="Canvas_MouseDown" ClipToBounds="True">
                <!-- Roads will be drawn programmatically in C# -->
            </Canvas>
        </Viewbox>

        <!-- Control Panel -->
        <Border Grid.Column="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
            <StackPanel Margin="20" VerticalAlignment="Top">
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#111827" TextWrapping="Wrap">Traffic Control</TextBlock>
                
                <Button Name="StartButton" Click="StartButton_Click" Padding="12" Margin="0,0,0,10" Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontSize="15" FontWeight="SemiBold">Start Simulation</TextBlock>
                </Button>
                
                <Button Name="StopButton" Click="StopButton_Click" Padding="12" Margin="0,0,0,10" Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand" IsEnabled="False">
                    <TextBlock FontSize="15" FontWeight="SemiBold">Stop Simulation</TextBlock>
                </Button>

                <Button Name="RestartButton" Click="RestartButton_Click" Padding="12" Margin="0,0,0,20" Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontSize="15" FontWeight="SemiBold">Restart</TextBlock>
                </Button>
                
                <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#374151">Vehicle Count</TextBlock>
                        <Border Background="#3B82F6" CornerRadius="12" HorizontalAlignment="Left" Padding="12,4">
                            <TextBlock Name="VehicleCountText" FontSize="16" FontWeight="Bold" Text="0" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
